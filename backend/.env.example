# ─── BuildX Backend Environment Variables ───────────────────
# Copy this file to .env and fill in your values

# Required: Your Groq API key (FREE at https://console.groq.com)
# 1. Sign up at https://console.groq.com
# 2. Go to API Keys → Create API Key
# 3. Paste it below
GROQ_API_KEY=gsk_your_key_here

# Required: PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/buildx
# Production: provided by your hosting platform (Railway, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/buildx

# Required: Secret key for signing JWT auth tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-64-char-string-here

# Server port (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# Comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173
# Production: your Vercel URL e.g. https://buildx.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
